<Configuration>
  <VGpu>Enable</VGpu>
  <Networking>Enable</Networking>
  <MappedFolders>
    <MappedFolder>
      <HostFolder>E:\code\win-bootstrap</HostFolder>
      <SandboxFolder>C:\Users\WDAGUtilityAccount\Desktop\win-bootstrap</SandboxFolder>
      <ReadOnly>true</ReadOnly>
    </MappedFolder>
  </MappedFolders>
  <LogonCommand>
    <Command>powershell.exe -ExecutionPolicy Bypass -Command "Start-Process powershell -ArgumentList '-NoExit', '-Command', 'cd C:\Users\WDAGUtilityAccount\Desktop\win-bootstrap; .\bootstrap.ps1'"</Command>
  </LogonCommand>
</Configuration>
